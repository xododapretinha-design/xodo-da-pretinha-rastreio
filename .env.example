# CONFIGURAÇÕES DO SERVIDOR XODÓ DA PRETINHA (EXEMPLO)
PORT=8080

# Chave de API do Resend (disparos reais de e-mail - requer domínio verificado)
# Obtenha em: https://resend.com
RESEND_API_KEY=sua_chave_do_resend_aqui

# Método Alternativo Gratuito: Envio via Gmail SMTP (Não requer domínio próprio)
# Configure o e-mail do Gmail e uma Senha de App gerada na sua Conta Google (Segurança -> Senhas de App)
GMAIL_USER=seu_email@gmail.com
GMAIL_APP_PASS=sua_senha_de_app_de_16_digitos_aqui

# Credenciais de Acesso Administrativo
ADMIN_USER=admin
ADMIN_PASSWORD=defina_uma_senha_segura

# Segredo para assinatura de Tokens de Sessão (JWT)
# Defina um valor longo e aleatório para segurança do admin
JWT_SECRET=defina_um_segredo_jwt_seguro_e_longo

# E-mail de remetente oficial (Substitua quando verificar o seu domínio no Resend)
EMAIL_FROM=Xodó da Pretinha <onboarding@resend.dev>

# Configurações do Supabase (obtenha em Project Settings -> API)
# Necessário para persistência cloud na Vercel (serverless)
SUPABASE_URL=https://seu-projeto-supabase.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_do_supabase_aqui
